{
	"name": "omni-copilot",
	"displayName": "OmniCopilot",
	"description": "Use models from multiple LLM platforms (DeepSeek, Kimi, Qwen, MiniMax, GLM, Volcengine Plan, Custom) in GitHub Copilot Chat as language model providers.",
	"version": "2.0.0",
	"publisher": "LyaQanYi",
	"license": "MIT",
	"repository": "https://github.com/LyaQanYi/OmniCopilot",
	"icon": "images/icon.png",
	"engines": {
		"vscode": "^1.108.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "deepseek",
				"displayName": "DeepSeek",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from platform.deepseek.com",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "zhipu",
				"displayName": "Bigmodel Plan",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from open.bigmodel.cn",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "moonshot",
				"displayName": "Moonshot (Kimi)",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from platform.moonshot.cn",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "qwen",
				"displayName": "Qwen",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from dashscope.aliyuncs.com",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "minimax",
				"displayName": "MiniMax",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from platform.minimaxi.com",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "volcengine",
				"displayName": "Volcengine Plan",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key from console.volcengine.com",
							"secret": true
						}
					}
				}
			},
			{
				"vendor": "custom-openai",
				"displayName": "Custom (OpenAI Compatible)",
				"configuration": {
					"properties": {
						"apiKey": {
							"type": "string",
							"description": "API key for the custom endpoint",
							"secret": true
						},
						"apiUrl": {
							"type": "string",
							"description": "Base URL of the OpenAI-compatible API (e.g. https://api.example.com/v1)"
						},
						"modelId": {
							"type": "string",
							"description": "Model ID to use (e.g. gpt-4o)"
						},
						"modelName": {
							"type": "string",
							"description": "Display name for the model"
						}
					}
				}
			}
		],
		"commands": [
			{
				"command": "omniCopilot.testConnection",
				"title": "OmniCopilot: Test Connection"
			},
			{
				"command": "omniCopilot.addCustomModelId",
				"title": "OmniCopilot: Add Custom Model ID"
			},
			{
				"command": "omniCopilot.setThinkingEffort",
				"title": "OmniCopilot: Set Thinking Effort"
			},
			{
				"command": "omniCopilot.toggleThinking",
				"title": "OmniCopilot: Toggle Thinking Mode"
			},
			{
				"command": "omniCopilot.setContextLength",
				"title": "OmniCopilot: Set Context Length"
			}
		],
		"configuration": {
			"title": "OmniCopilot",
			"properties": {
				"omniCopilot.enableThinking": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"always",
						"never"
					],
					"enumDescriptions": [
						"Auto — use each model's default thinking setting",
						"Always — force thinking on for all models that support it",
						"Never — disable thinking for all models"
					],
					"description": "Control whether thinking/reasoning mode is enabled"
				},
				"omniCopilot.thinkingEffort": {
					"type": "string",
					"default": "medium",
					"enum": [
						"low",
						"medium",
						"high"
					],
					"enumDescriptions": [
						"Low thinking effort — faster responses",
						"Medium thinking effort — balanced",
						"High thinking effort — deeper reasoning"
					],
					"description": "Default thinking effort level for models that support reasoning"
				},
				"omniCopilot.contextLength": {
					"type": "string",
					"default": "default",
					"enum": [
						"default",
						"4k",
						"8k",
						"16k",
						"32k",
						"64k",
						"128k",
						"256k",
						"512k",
						"1m",
						"custom"
					],
					"enumDescriptions": [
						"Use each model's default context length",
						"Limit to 4,096 tokens",
						"Limit to 8,192 tokens",
						"Limit to 16,384 tokens",
						"Limit to 32,768 tokens",
						"Limit to 65,536 tokens",
						"Limit to 131,072 tokens",
						"Limit to 262,144 tokens",
						"Limit to 524,288 tokens",
						"Limit to 1,048,576 tokens",
						"Use a custom context length (set below)"
					],
					"description": "Maximum input context length sent to models"
				},
				"omniCopilot.customContextLength": {
					"type": "number",
					"default": 131072,
					"minimum": 1024,
					"maximum": 2097152,
					"description": "Custom maximum input context length (used when Context Length is set to Custom)"
				},
				"omniCopilot.enableVision": {
					"type": "boolean",
					"default": true,
					"description": "Enable vision/image input for models that support it"
				},
				"omniCopilot.deepseek.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for DeepSeek (added to preset list)"
				},
				"omniCopilot.zhipu.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for Zhipu/GLM (added to preset list)"
				},
				"omniCopilot.moonshot.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for Moonshot/Kimi (added to preset list)"
				},
				"omniCopilot.qwen.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for Qwen (added to preset list)"
				},
				"omniCopilot.minimax.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for MiniMax (added to preset list)"
				},
				"omniCopilot.volcengine.customModelIds": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Custom model IDs for Volcengine (added to preset list)"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "20.19.29",
		"@types/vscode": "1.108.0",
		"@vscode/vsce": "^3.9.1",
		"typescript": "5.9.3"
	}
}
